use_default_settings: true

general:
  instance_name: "SearXNG"
  debug: false

server:
  secret_key: "{{ searxng_secret_key }}"
  limiter: true
  image_proxy: true
  bind_address: "0.0.0.0:8080"
  base_url: "https://searxng.bytedev.duckdns.org/"

search:
  formats:
    - html
    - json

redis:
  url: "redis://:{{ searxng_redis_password }}@redis.bytedev.duckdns.org:6379/0"